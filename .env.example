APP_ENV=development
LOG_LEVEL=INFO

ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
ALPACA_CRYPTO_DATA_WS_URL=wss://stream.data.alpaca.markets/v1beta3/crypto/us
ALPACA_TRADING_STREAM_WS_URL=wss://paper-api.alpaca.markets/stream
ALPACA_ACCOUNT_SYNC_SECONDS=15

TRADING_SYMBOL=ETH/USD
DECISION_INTERVAL_SECONDS=60
DECISION_LOOP_ITERATIONS=1
MAX_TRADES_PER_HOUR=6
MAX_RISK_PER_TRADE_PCT=0.005
MAX_DAILY_LOSS_PCT=0.02
MAX_POSITION_NOTIONAL_USD=100
MAX_SPREAD_BPS=20
MIN_DECISION_CONFIDENCE=0.6
COOLDOWN_SECONDS_AFTER_TRADE=60
ENABLE_AGENT_ORDERS=false
ENABLE_PAPER_TEST_ORDER=false
PAPER_TEST_ORDER_NOTIONAL_USD=25
JOURNAL_PATH=var/decision_journal.jsonl
LESSONS_PATH=var/lessons.jsonl
REVIEW_SUMMARY_PATH=var/review_summary.json
EVALUATION_REPORT_PATH=var/evaluation_report.json
STRATEGY_ADVICE_PATH=var/strategy_advice.md
EVALUATION_MIN_CLOSED_TRADES=1
EVALUATION_MIN_SCORE_IMPROVEMENT=5
EVALUATION_MAX_ADDITIONAL_DRAWDOWN_BPS=50
BACKTEST_REPORT_PATH=var/backtest_report.json
BACKTEST_TIMEFRAME=1Min
BACKTEST_LOCATION=us
BACKTEST_LOOKBACK_DAYS=365
BACKTEST_TRAIN_WINDOW_DAYS=90
BACKTEST_TEST_WINDOW_DAYS=30
BACKTEST_STEP_DAYS=30
BACKTEST_WARMUP_BARS=20
BACKTEST_STARTING_CASH_USD=10000

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1

V51_OPENROUTER_API_KEY=
V51_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
V51_OPENROUTER_MODEL=deepseek/deepseek-v3.2
V51_ENTRY_REASONING_ENABLED=true
V51_MANAGER_REASONING_ENABLED=false
V51_AGENT_NAME=mt5_v51_primary
V51_BRIDGE_HOST=127.0.0.1
V51_BRIDGE_PORT=8091
V51_BRIDGE_ID=mt5-v51-local
V51_MT5_SYMBOL=BTCUSD
V51_MT5_ACCOUNT_MODE=hedging
V51_MT5_ENTRY_TIMEOUT_SECONDS=60
V51_MT5_MANAGER_SWEEP_SECONDS=15
V51_MT5_ENABLE_TRADE_COMMANDS=false
V51_MT5_SHADOW_MODE=true
V51_MAX_TRADES_PER_HOUR=15
V51_MAX_SPREAD_BPS=12
V51_STALE_AFTER_SECONDS=5
V51_MIN_DECISION_CONFIDENCE=0.50
V51_MIN_RISK_FRACTION=0.002
V51_MAX_RISK_FRACTION=0.005
V51_MAX_DAILY_LOSS_PCT=0.015

# Supabase application access
SUPABASE_URL=
SUPABASE_DB_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase project management / MCP access
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=
